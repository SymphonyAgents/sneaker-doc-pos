PORT=3001
AMOUNT_CONVERSION_RATE=100000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
CORS_ORIGIN=http://localhost:3000
OTP_ENABLED=1
# Email (Resend) — scaffold ready, uncomment EmailService.send() when integrating
RESEND_API_KEY=re_your_api_key_here

# SMS (Semaphore PH) — set SMS_ENABLED=true and add API key to activate
# Sign up at https://semaphore.co to get your API key
SMS_ENABLED=false
SEMAPHORE_API_KEY=your_semaphore_api_key_here
SEMAPHORE_SENDER_NAME=SneakerDoc
